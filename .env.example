# =============================================================================
# PERMIT.IO CONFIGURATION
# =============================================================================
# Get your API key from: https://app.permit.io -> Settings -> API Keys
# This key connects your FastAPI app to your Permit.io project
PERMIT_IO_KEY=permit_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DATABASE CONFIGURATION (for production - currently using SQLite)
# =============================================================================
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changethis
# POSTGRES_DB=assetwatch

# =============================================================================
# OTHER SETTINGS
# =============================================================================
# SECRET_KEY=changethis
# ENVIRONMENT=local
# FRONTEND_HOST=http://localhost:5173
# PROJECT_NAME=AssetWatch
# FIRST_SUPERUSER=admin@assetwatch.com
# FIRST_SUPERUSER_PASSWORD=changethis

# =============================================================================
# BEACON CHATBOT (AI Assistant)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# EMAIL CONFIGURATION (SendGrid)
# =============================================================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=AssetWatch

# Frontend URL for password reset and verification links
FRONTEND_HOST=http://localhost:5173

